<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NZ Stunt School — Upcoming Sessions Jul–Sep 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black:   #0a0a0a;
    --dark:    #111111;
    --card:    #161616;
    --gold:    #C9972A;
    --gold-lt: #E8B84B;
    --gold-dk: #8B6510;
    --white:   #F5F0E8;
    --grey:    #777;
    --green:   #4a7c59;
  }
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    padding-bottom: 60px;
  }

  /* HEADER */
  header {
    background: linear-gradient(135deg, #0a0a0a 60%, #1a1200 100%);
    border-bottom: 2px solid var(--gold-dk);
    padding: 40px 40px 32px;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: 'NZSS';
    position: absolute; right: -10px; top: -10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 160px; font-weight: 900;
    color: rgba(201,151,42,0.05);
    line-height: 1; pointer-events: none; user-select: none;
  }
  .header-badge {
    display: inline-block;
    background: var(--gold); color: var(--black);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; font-size: 12px;
    letter-spacing: 2px; padding: 4px 12px;
    margin-bottom: 14px; text-transform: uppercase;
  }
  header h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(30px, 5vw, 58px);
    font-weight: 900; line-height: 1;
    text-transform: uppercase; letter-spacing: -1px;
  }
  header h1 span { color: var(--gold); }
  header p { margin-top: 10px; font-size: 14px; color: #999; font-style: italic; }

  /* MONTH SECTIONS */
  .month-block { padding: 0 32px; margin-top: 40px; }
  .month-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px; font-weight: 700;
    letter-spacing: 4px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 14px;
    display: flex; align-items: center; gap: 12px;
  }
  .month-label::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, var(--gold-dk), transparent);
  }

  /* WEEK ROW */
  .week-row {
    display: flex; align-items: flex-start; gap: 0;
    margin-bottom: 10px;
  }
  .week-date {
    flex-shrink: 0; width: 100px;
    padding: 14px 12px 14px 0;
    text-align: right;
  }
  .week-date .day-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; color: var(--grey);
    text-transform: uppercase;
  }
  .week-date .day-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px; font-weight: 900;
    color: var(--gold); line-height: 1;
  }
  .week-date .month-short {
    font-size: 11px; color: var(--grey); text-transform: uppercase;
    letter-spacing: 1px;
  }
  .week-line {
    flex-shrink: 0; width: 2px;
    background: linear-gradient(180deg, var(--gold-dk), transparent);
    margin: 14px 18px 0;
    align-self: stretch; min-height: 100%;
  }
  .week-events {
    flex: 1; display: flex; flex-direction: column; gap: 8px;
    padding: 6px 0 12px;
  }

  /* EVENT CARD */
  .event-card {
    background: var(--card);
    border: 1px solid rgba(201,151,42,0.12);
    border-left: 3px solid var(--gold-dk);
    border-radius: 3px;
    text-decoration: none;
    color: var(--white);
    display: block;
    padding: 12px 16px;
    transition: background 0.15s, border-left-color 0.15s, transform 0.1s;
    position: relative;
  }
  .event-card:hover {
    background: rgba(201,151,42,0.1);
    border-left-color: var(--gold);
    transform: translateX(3px);
  }
  .event-card.multi { border-left-color: #5a8a9f; }
  .event-card.multi:hover { border-left-color: #7ab8d4; }
  .event-card.highlight { border-left-color: var(--green); }
  .event-card.highlight:hover { border-left-color: #6ab882; }

  .event-top {
    display: flex; align-items: baseline;
    justify-content: space-between; gap: 12px;
    flex-wrap: wrap;
  }
  .event-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--white);
  }
  .event-card:hover .event-name { color: var(--gold-lt); }
  .event-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px; font-weight: 700;
    color: var(--gold); flex-shrink: 0;
  }
  .event-meta {
    margin-top: 4px; font-size: 13px; color: var(--grey);
    display: flex; gap: 14px; flex-wrap: wrap;
  }
  .event-meta span { display: flex; align-items: center; gap: 4px; }
  .event-note {
    margin-top: 6px; font-size: 12px;
    color: #888; font-style: italic;
  }

  /* MULTI-LINK */
  .multi-links {
    margin-top: 10px;
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .multi-link {
    display: inline-block;
    background: rgba(90,138,159,0.15);
    border: 1px solid rgba(90,138,159,0.3);
    border-radius: 2px;
    padding: 5px 12px;
    font-size: 12px; font-weight: 600;
    color: #7ab8d4;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    font-family: 'Barlow Condensed', sans-serif;
    letter-spacing: 0.5px;
  }
  .multi-link:hover {
    background: rgba(90,138,159,0.3);
    color: #a8d8f0;
  }

  /* PROMO BANNER */
  .promo-wrap { padding: 0 32px; margin-top: 48px; }
  .promo-banner {
    background: linear-gradient(135deg, #1a1200, #0f0c00);
    border: 1px solid var(--gold-dk);
    border-left: 4px solid var(--gold);
    border-radius: 3px;
    padding: 24px 28px;
    display: flex; align-items: center;
    justify-content: space-between; gap: 20px;
    flex-wrap: wrap;
  }
  .promo-text h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px; font-weight: 900;
    text-transform: uppercase; letter-spacing: 1px;
    color: var(--gold);
  }
  .promo-text p { font-size: 14px; color: #aaa; margin-top: 4px; }
  .promo-price {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 42px; font-weight: 900;
    color: var(--gold-lt); line-height: 1;
    text-align: right;
  }
  .promo-price small {
    display: block; font-size: 14px;
    color: var(--grey); font-weight: 400;
    text-decoration: line-through;
  }
  .promo-price .save {
    display: block; font-size: 13px;
    color: #6ab882; font-weight: 600;
    text-decoration: none;
  }

  /* OPEN MAT TIP */
  .tip-wrap { padding: 0 32px; margin-top: 16px; }
  .tip {
    background: rgba(74,124,89,0.1);
    border: 1px solid rgba(74,124,89,0.25);
    border-left: 3px solid var(--green);
    border-radius: 3px;
    padding: 14px 18px;
    font-size: 13px; color: #aaa; font-style: italic;
  }
  .tip strong { color: #6ab882; font-style: normal; }

  /* FOOTER */
  footer {
    border-top: 1px solid #222;
    margin-top: 48px; padding: 20px 32px;
    display: flex; justify-content: space-between;
    align-items: center; flex-wrap: wrap; gap: 10px;
  }
  footer p { font-size: 12px; color: var(--grey); font-style: italic; }
  footer a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px; font-weight: 600;
    color: var(--gold); text-decoration: none;
    letter-spacing: 1px;
  }
  footer a:hover { color: var(--gold-lt); }

  @media (max-width: 600px) {
    header { padding: 28px 20px 22px; }
    .month-block, .promo-wrap, .tip-wrap, footer { padding-left: 16px; padding-right: 16px; }
    .week-date { width: 72px; }
    .week-line { margin: 14px 10px 0; }
    .promo-price { font-size: 30px; }
  }
</style>
</head>
<body>

<header>
  <div class="header-badge">Upcoming Sessions</div>
  <h1>Upcoming <span>Training</span></h1>
  <p>July · August · September 2026 &nbsp;·&nbsp; NZ Stunt School</p>
</header>

<!-- JULY -->
